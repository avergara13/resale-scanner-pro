# Resale Scanner Pro — environment template
# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
#
# Client-facing (VITE_*) values are bundled into the browser build — rotate any
# key that ever reaches a public deploy. Server-only values (no VITE_ prefix)
# stay on Railway.

# ── LLM providers ────────────────────────────────────────────────────────────
# Gemini is the primary vision + optimization model.
# Get a key at https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Optional — Claude fallback for listing optimization.
# https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=

# ── Google Cloud (Vision + Custom Search) ────────────────────────────────────
# Used by src/lib/google-lens-service.ts for reverse-image search.
#
# To fix recurring HTTP 403 from /customsearch or /vision.googleapis.com:
#   1. https://console.cloud.google.com/apis/library — enable both
#        "Cloud Vision API" and "Custom Search API" on the same project.
#   2. https://console.cloud.google.com/billing — ensure billing is active
#        (both APIs require a billing account even within the free tier).
#   3. https://console.cloud.google.com/apis/credentials — confirm the key
#        has NO referer restriction (Vercel/Railway preview URLs change) or
#        add *.up.railway.app + *.vercel.app + localhost to the allowlist.
VITE_GOOGLE_API_KEY=
VITE_GOOGLE_SEARCH_ENGINE_ID=

# ── Supabase ─────────────────────────────────────────────────────────────────
# https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only service role (Railway). Never expose in a VITE_ variable.
SUPABASE_SERVICE_ROLE_KEY=

# ── Notion ───────────────────────────────────────────────────────────────────
# https://www.notion.so/my-integrations
VITE_NOTION_API_KEY=

# ── eBay ─────────────────────────────────────────────────────────────────────
# Server-side only — the Browse API proxy in server.js uses client_credentials
# OAuth to fetch a short-lived Application Access Token on demand.
#   https://developer.ebay.com/my/keys
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
# Redirect URI for the user-auth flow (Authorization Code grant). Not needed
# for Browse/market-search, which uses client_credentials.
EBAY_REDIRECT_URI=
# Set to 1 to target api.sandbox.ebay.com instead of api.ebay.com.
EBAY_SANDBOX=0
